# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Cloud (Render sets RENDER=true automatically)
# CLOUD=true
# PRELOAD_ML=false
# DATA_DIR=/tmp/findai

# Upload limit (bytes) — 50 MB cloud, 100 MB local
MAX_FILE_SIZE=104857600

# Hugging Face cache (optional — defaults to ~/.cache locally)
# HF_HOME=/tmp/huggingface
# TRANSFORMERS_CACHE=/tmp/huggingface
